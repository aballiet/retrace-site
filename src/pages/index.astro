---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoMark from '../components/brand/LogoMark.astro';
import Glyph from '../components/Glyph.astro';
import HubAndSpoke from '../components/landing/HubAndSpoke.astro';
import Rivers from '../components/landing/Rivers.astro';
import InteractiveDemoSection from '../components/InteractiveDemoSection.astro';

const sources = {
	ext: [
		['ChatGPT', 'chatgpt'],
		['Claude', 'claude'],
	],
	import: [
		['WhatsApp', 'whatsapp'],
		['Messenger', 'messenger'],
		['Instagram', 'instagram'],
		['Keep', 'keep'],
		['Calendar', 'calendar'],
	],
	sync: [
		['WhatsApp', 'whatsapp'],
		['Obsidian', 'obsidian'],
	],
};

const people = [
	{ name: 'Mae Okafor', platform: 'imessage', recently: 'the move', tie: 'Inner circle' },
	{ name: 'Hugo Bellini', platform: 'whatsapp', recently: 'career', tie: 'Inner circle' },
	{ name: 'Dad', platform: 'imessage', recently: 'Sunday call', tie: 'Active' },
];

const stats: [string, string][] = [
	['10', 'sources'],
	['$0', 'API costs'],
	['MIT', 'licensed'],
	['100%', 'your data'],
];
---

<BaseLayout title="Retrace - rediscover your conversations">
	<!-- ============ HERO ============ -->
	<section class="hero" id="top">
		<div class="hero-grid">
			<div class="hero-text" data-inview>
				<div class="pill reveal">
					<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
					<span>your data is stored locally. you choose what leaves.</span>
				</div>
				<h1 class="hero-h1 reveal reveal-delay-1">
					Retrace your
					<span class="rotating-word" id="rotating-word">conversations.</span>
				</h1>
				<p class="hero-sub reveal reveal-delay-2">
					Your chats, notes, and music are scattered across a dozen apps. Retrace
					pulls them into <strong>one private context layer</strong>. Searchable, and
					entirely on your Mac.
				</p>
				<div class="hero-buttons reveal reveal-delay-3">
					<a href="/#download" class="btn btn-primary">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.142-1.64 3.248-1.68.03.13.05.28.05.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.09-2.383 1.37-2.383 4.19 0 3.26 2.854 4.42 2.955 4.45z"/></svg>
						Download for Mac
					</a>
					<a href="#demo" class="btn btn-secondary">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 4 20 12 6 20 6 4"/></svg>
						See it live
					</a>
				</div>
				<p class="hero-caption reveal reveal-delay-4">free · runs entirely on your Mac · no account</p>
			</div>

			<div class="hero-visual reveal" data-inview>
				<HubAndSpoke />
			</div>
		</div>
	</section>

	<!-- ============ SHOWCASE GRID ============ -->
	<section class="showcase">
		<div class="wrap">
			<div class="section-head" data-inview>
				<div class="eyebrow eyebrow-teal reveal">what you can do</div>
				<h2 class="reveal reveal-delay-1">Explore, rediscover, <span class="accent">reflect.</span></h2>
				<p class="reveal reveal-delay-2">Browse old conversations. Find forgotten moments. See patterns across platforms.</p>
			</div>

			<div class="showcase-grid" data-inview>
				<a href="/features#search" class="show-card reveal">
					<span class="chip chip-teal">Search</span>
					<h3>Search across every conversation</h3>
					<p>Semantic search across every platform. Find conversations by meaning, not just keywords.</p>
					<div class="show-mini">
						<div class="mini-search">
							<svg width="13" height="13" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
							restaurant recommendation
						</div>
						<div class="mini-row"><span class="tag" style="color:var(--platform-whatsapp);background:rgba(37,211,102,.1);">WhatsApp</span>"You have to try Maison Plisson"</div>
						<div class="mini-row"><span class="tag" style="color:var(--platform-chatgpt);background:rgba(16,163,127,.1);">ChatGPT</span>"Based on your preferences..."</div>
						<div class="mini-row"><span class="tag" style="color:var(--platform-keep);background:rgba(251,188,4,.15);">Keep</span>"Paris food list: Maison Plisson..."</div>
					</div>
				</a>

				<a href="/features#network" class="show-card reveal reveal-delay-1">
					<span class="chip chip-teal">Network</span>
					<h3>See your relationships evolve</h3>
					<p>Force-directed graph with tie-strength scoring and timelapse animation.</p>
					<div class="show-mini center">
						<svg viewBox="30 35 240 170" class="mini-graph">
							<line x1="150" y1="110" x2="80" y2="60" stroke="var(--color-accent)" stroke-width="2" opacity="0.6"/>
							<line x1="150" y1="110" x2="220" y2="70" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>
							<line x1="150" y1="110" x2="100" y2="170" stroke="var(--color-teal)" stroke-width="2.5" opacity="0.7"/>
							<line x1="150" y1="110" x2="60" y2="130" stroke="var(--color-teal)" stroke-width="1.5" opacity="0.5"/>
							<circle cx="150" cy="110" r="14" fill="var(--color-accent)" opacity="0.9"/><text x="150" y="114" text-anchor="middle" fill="white" font-size="8" font-weight="600">You</text>
							<circle cx="80" cy="60" r="10" fill="var(--color-teal)" opacity="0.8"/><text x="80" y="44" text-anchor="middle" fill="var(--color-text-muted)" font-size="7.5">Sarah</text>
							<circle cx="100" cy="170" r="11" fill="var(--color-teal)" opacity="0.8"/><text x="100" y="190" text-anchor="middle" fill="var(--color-text-muted)" font-size="7.5">Tom</text>
							<circle cx="220" cy="70" r="8" fill="var(--color-accent-light)" opacity="0.6"/><text x="220" y="56" text-anchor="middle" fill="var(--color-text-faint)" font-size="7">Maya</text>
							<circle cx="60" cy="130" r="7" fill="var(--color-accent-light)" opacity="0.5"/><text x="45" y="125" text-anchor="middle" fill="var(--color-text-faint)" font-size="7">Alex</text>
						</svg>
						<div class="legend">
							<span><span class="dot" style="background:var(--color-teal);"></span>Inner circle</span>
							<span><span class="dot" style="background:var(--color-accent-light);"></span>Active</span>
							<span><span class="dot" style="background:var(--color-text-faint);opacity:.5;"></span>Extended</span>
						</div>
					</div>
				</a>

				<a href="/features#capsules" class="show-card reveal reveal-delay-2">
					<span class="chip chip-teal">Capsules</span>
					<h3>This time last year</h3>
					<p>AI-powered then-and-now comparisons. See what changed and what you forgot.</p>
					<div class="show-mini capsule">
						<div class="capsule-col">
							<div class="mono-label">Apr 2025</div>
							<div class="capsule-msg"><span class="tag" style="color:var(--platform-chatgpt);background:rgba(16,163,127,.1);">ChatGPT</span>"Should I quit? I keep going back and forth"</div>
						</div>
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="capsule-arrow"><path d="M5 12h14M13 6l6 6-6 6" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
						<div class="capsule-col">
							<div class="mono-label accent">Apr 2026</div>
							<div class="capsule-msg"><span class="tag" style="color:var(--platform-messenger);background:rgba(0,132,255,.1);">Messenger</span>"Six months in, the fear is completely gone"</div>
						</div>
					</div>
				</a>

				<a href="/features#mcp" class="show-card reveal reveal-delay-3">
					<span class="chip chip-teal">Chat</span>
					<h3>Reflect with Claude</h3>
					<p>Claude sees only what you allow. Explore your history or reflect on it.</p>
					<div class="show-mini">
						<div class="chat-q">What idea have I kept coming back to?</div>
						<div class="chat-a">
							<div>One thread runs through 23 conversations across 8 months: building something of your own.</div>
							<div class="chat-meta">
								<span><span style="color:var(--platform-chatgpt);font-weight:600;">ChatGPT</span> 12 conversations</span>
								<span><span style="color:var(--platform-whatsapp);font-weight:600;">WhatsApp</span> 8 messages</span>
							</div>
						</div>
					</div>
				</a>
			</div>
		</div>
	</section>

	<!-- ============ CONNECT THE DOTS ============ -->
	<section class="narrative">
		<div class="narrative-intro" data-inview>
			<div class="eyebrow eyebrow-accent reveal">why this is different</div>
			<h2 class="reveal reveal-delay-1">No app sees the full picture. <span class="accent">Retrace connects the dots.</span></h2>
			<p class="reveal reveal-delay-2">Your life doesn't happen on one platform. A single decision might span a ChatGPT brainstorm, a WhatsApp conversation with a friend, and an Obsidian note where you planned next steps. Retrace is the only place where all three connect.</p>
		</div>

		<!-- Rediscovery -->
		<div class="nrow" data-inview>
			<div class="nrow-text reveal">
				<div class="eyebrow eyebrow-accent">rediscovery</div>
				<h3>It remembers what you forgot.</h3>
				<p>An idea you mentioned once in January, forgot, then brought up again in April. Retrace sees the thread even when you don't. Quiet cards surface what was happening this time last year. Nothing nudges you, the insights simply wait until you come back.</p>
			</div>
			<div class="nrow-visual reveal reveal-delay-1">
				<div class="insight-card">
					<div class="insight-head"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2"/></svg><span class="insight-eyebrow">this time last year</span></div>
					<p class="insight-body">You and Mae spent weeks hunting for an apartment in Lisbon to finally live together, debating every neighborhood late into the night.</p>
					<div class="insight-foot">
						<span class="avatar" style="border-color:var(--platform-imessage);">M</span>
						<span class="insight-foot-text">7 conversations across</span>
						<span class="insight-glyphs">
							<Glyph name="imessage" size={16} />
							<Glyph name="whatsapp" size={16} />
							<Glyph name="chatgpt" size={16} />
						</span>
					</div>
				</div>
			</div>
		</div>

		<!-- Life Rivers (flipped) -->
		<div class="nrow flip" data-inview>
			<div class="nrow-visual reveal">
				<div class="surface-card">
					<Rivers />
				</div>
			</div>
			<div class="nrow-text reveal reveal-delay-1">
				<div class="eyebrow eyebrow-accent">life rivers</div>
				<h3>It shows the shape of your attention.</h3>
				<p>Watch what you talked about flow over time, by person or by topic, as a living streamgraph. Wider streams are the weeks something really mattered.</p>
			</div>
		</div>

		<!-- Network -->
		<div class="nrow" data-inview>
			<div class="nrow-text reveal">
				<div class="eyebrow eyebrow-accent">network</div>
				<h3>The people who shape you, over the years.</h3>
				<p>Every relationship you live through is here, the close ones and the ones that drifted. Watch them grow, fade, and sometimes come back, across the years.</p>
			</div>
			<div class="nrow-visual reveal reveal-delay-1">
				<div class="surface-card people-card">
					{
						people.map((p, i) => (
							<div class:list={['person', { 'person-border': i > 0 }]}>
								<span class="avatar" style={`border-color:var(--platform-${p.platform});`}>
									{p.name.split(' ').map((w) => w[0]).join('').slice(0, 2)}
								</span>
								<div class="person-main">
									<div class="person-name">{p.name}</div>
									<div class="person-recent">recently: {p.recently}</div>
								</div>
								<span class="person-tie">{p.tie}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- ============ TWO REGISTERS ============ -->
	<section class="registers">
		<div class="wrap-narrow">
			<div class="section-head" data-inview>
				<div class="eyebrow eyebrow-muted reveal">how it stays honest</div>
				<h2 class="reveal reveal-delay-1">Every reflection traces back to a real message.</h2>
			</div>
			<div class="registers-grid" data-inview>
				<div class="reg-insight reveal">
					<div class="reg-label">the reflection</div>
					<div class="insight-card">
						<div class="insight-head"><span class="sparkle">&#10022;</span><span class="insight-eyebrow">synthesized</span></div>
						<p class="insight-body">For a month you and Mae slowly talked each other into a trip to Berlin, trading songs and venues until it felt real.</p>
						<div class="reg-tags">
							<span class="tag-pill positive">excited</span>
							<span class="tag-pill neutral">the trip</span>
						</div>
					</div>
				</div>

				<div class="reg-link reveal reveal-delay-1">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
					<span>traces back</span>
				</div>

				<div class="reg-raw reveal reveal-delay-2">
					<div class="reg-label">the evidence</div>
					<div class="evidence">
						<div class="evidence-card">
							<div class="evidence-head"><Glyph name="whatsapp" size={14} /><span>Mae · WhatsApp</span><span class="evidence-time">Fri 11:02 PM</span></div>
							<p>"ok this set is unreal, this has to be our soundtrack"</p>
							<p class="evidence-link">[soundcloud.com/link]</p>
						</div>
						<div class="evidence-card">
							<div class="evidence-head"><Glyph name="instagram" size={14} /><span>Mae · Instagram</span><span class="evidence-time">Wed 9:30 PM</span></div>
							<p>"found a tiny club in kreuzberg we have to see 🕺"</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ DEMO (real, preserved) ============ -->
	<InteractiveDemoSection />

	<!-- ============ SOURCES PREVIEW ============ -->
	<section class="sources-preview">
		<div class="wrap-narrow">
			<div class="section-head" data-inview>
				<div class="eyebrow eyebrow-accent reveal">your sources, your control</div>
				<h2 class="reveal reveal-delay-1">You're sitting on years of insight.</h2>
				<p class="reveal reveal-delay-2">Export your data, import it locally, and for the first time see the full picture. Your conversations become your journal, your timeline, your searchable memory.</p>
			</div>
			<div class="sources-grid" data-inview>
				<div class="source-col reveal">
					<div class="mono-label">browser extension</div>
					{sources.ext.map(([name, p]) => <div class="source-row"><Glyph name={p} size={19} /><span>{name}</span></div>)}
				</div>
				<div class="source-col reveal reveal-delay-1">
					<div class="mono-label">import</div>
					{sources.import.map(([name, p]) => <div class="source-row"><Glyph name={p} size={19} /><span>{name}</span></div>)}
				</div>
				<div class="source-col reveal reveal-delay-2">
					<div class="mono-label">live sync</div>
					{sources.sync.map(([name, p]) => <div class="source-row"><Glyph name={p} size={19} /><span>{name}</span></div>)}
				</div>
			</div>
		</div>
	</section>

	<!-- ============ PRIVACY BAND ============ -->
	<section class="privacy-band">
		<div class="privacy-watermark" aria-hidden="true">
			<LogoMark size={520} variant="mono" color="#faf3ea" gradId="privacyWatermark" />
		</div>
		<div class="wrap-narrow privacy-inner">
			<div class="privacy-head" data-inview>
				<div class="eyebrow privacy-eyebrow reveal">privacy by architecture</div>
				<h2 class="reveal reveal-delay-1">Intimate by default, not by promise.</h2>
			</div>
			<div class="privacy-grid" data-inview>
				<div class="privacy-card reveal">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-terracotta-light)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
					<h3>Your data is stored locally</h3>
					<p>Your conversations are structured and indexed on your own machine. No telemetry, no tracking.</p>
				</div>
				<div class="privacy-card reveal reveal-delay-1">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-terracotta-light)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
					<h3>You choose what leaves</h3>
					<p>Deep reflection uses Claude, and it sees only what you allow. Labels decide exactly what's shared.</p>
				</div>
				<div class="privacy-card reveal reveal-delay-2">
					<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-terracotta-light)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
					<h3>No engagement bait</h3>
					<p>No badges, no red dots, no notifications. Open source, MIT licensed. Insights wait quietly until you return.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ CTA ============ -->
	<section class="cta" id="download">
		<div class="cta-inner" data-inview>
			<div class="cta-mark reveal">
				<svg width="58" height="58" viewBox="0 0 100 100">
					<defs>
						<radialGradient id="sphCta" cx="0.36" cy="0.30" r="0.85"><stop offset="0" stop-color="#dd9059"/><stop offset="0.5" stop-color="#c8723a"/><stop offset="1" stop-color="#2f7a72"/></radialGradient>
						<linearGradient id="ripCta" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#c8723a"/><stop offset="1" stop-color="#3a8f85"/></linearGradient>
					</defs>
					<circle cx="50" cy="35" r="21" fill="url(#sphCta)"/>
					<rect x="21" y="63" width="58" height="6" rx="3" fill="url(#ripCta)" opacity="0.72"/>
					<rect x="28" y="74" width="44" height="4" rx="2" fill="#3a8f85" opacity="0.4"/>
					<rect x="34" y="82" width="32" height="4" rx="2" fill="#3a8f85" opacity="0.22"/>
				</svg>
			</div>
			<h2 class="reveal reveal-delay-1">The patterns are already there. Retrace just helps you see them.</h2>
			<div class="cta-buttons reveal reveal-delay-2">
				<a href="/#download" class="btn btn-primary">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.142-1.64 3.248-1.68.03.13.05.28.05.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.09-2.383 1.37-2.383 4.19 0 3.26 2.854 4.42 2.955 4.45z"/></svg>
					Download for Mac
				</a>
				<a href="#demo" class="btn btn-secondary">Open the demo</a>
			</div>
			<div class="cta-stats reveal reveal-delay-3">
				{stats.map(([v, l]) => <div class="stat"><span class="stat-v">{v}</span><span class="stat-l">{l}</span></div>)}
			</div>
			<p class="cta-caption reveal reveal-delay-4">free · runs entirely on your Mac · macOS 12+ · MIT licensed</p>
		</div>
	</section>

	<script>
		function initRotator() {
			const span = document.getElementById('rotating-word');
			if (!span) return;
			if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
			const words = ['conversations.', 'music.', 'journal.', 'growth.'];
			let i = 0;
			window.setInterval(() => {
				span.style.opacity = '0';
				span.style.transform = 'translateY(10px)';
				window.setTimeout(() => {
					i = (i + 1) % words.length;
					span.textContent = words[i];
					span.style.opacity = '1';
					span.style.transform = 'translateY(0)';
				}, 400);
			}, 2600);
		}
		initRotator();
		document.addEventListener('astro:page-load', initRotator);
	</script>

	<style>
		.wrap { max-width: 1180px; margin: 0 auto; padding: 0 24px; }
		.wrap-narrow { max-width: 1080px; margin: 0 auto; padding: 0 24px; }

		/* shared section heads */
		.section-head { text-align: center; max-width: 600px; margin: 0 auto var(--space-3xl); }
