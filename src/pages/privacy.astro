---
import BaseLayout from '../layouts/BaseLayout.astro';

const dataPath = [
	{ label: 'sources', text: 'ChatGPT, Claude, WhatsApp, Messenger, Instagram, SMS, Obsidian, Calendar, Keep.' },
	{ label: 'import', text: 'Extension, drag-and-drop, live sync. All local. No data sent anywhere.' },
	{ label: 'process', text: 'On-device LLM extracts topics, summaries, embeddings. Runs on your hardware.' },
	{ label: 'store', text: 'One SQLite file on your laptop. That\'s it.' },
];

const techDetails: [string, string, boolean][] = [
	['Database', '~/.retrace/retrace.db', true],
	['Raw payloads', '~/.retrace/raw/', true],
	['LLM models', '~/.retrace/models/', true],
	['Telemetry', 'None. Zero. Nothing phones home.', false],
	['Analytics', "None. We don't know you exist.", false],
	['License', 'MIT', false],
];
---

<BaseLayout active="privacy" title="Privacy - Retrace" description="Your data is stored locally. You choose what leaves. How Retrace's local-first architecture keeps your conversations private.">
	<!-- HEADER -->
	<header class="page-header" data-inview>
		<div class="wrap-760">
			<div class="eyebrow eyebrow-accent reveal">privacy by architecture</div>
			<h1 class="reveal reveal-delay-1">Your data is stored locally. <span class="accent">You choose what leaves.</span></h1>
			<p class="reveal reveal-delay-2">Retrace is built on a simple principle: your most personal conversations are structured on your own machine, and you decide exactly what each tool can see.</p>
		</div>
	</header>

	<!-- PILLARS -->
	<section class="pillars">
		<div class="wrap">
			<div class="pillar-grid" data-inview>
				<div class="pillar reveal">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
					<h2>Your data is stored locally</h2>
					<p>SQLite database in <code>~/.retrace/</code>. No accounts, no telemetry. Conversations, topics, embeddings, and reflections all live on your laptop.</p>
					<div class="pillar-foot">
						<code class="code-teal">~/.retrace/retrace.db</code>
						<span>One file. Your file. Copy it, back it up, delete it.</span>
					</div>
				</div>
				<div class="pillar reveal reveal-delay-1">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1 1"/><path d="M14 11a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1-1"/></svg>
					<h2>You choose the intelligence</h2>
					<p>Reflection is optional and never tied to one provider. Connect Claude, Codex, or a model you run yourself over MCP. Retrace works on its own first, the AI is something you bring.</p>
					<div class="pillar-foot"><span>MCP · Claude · Codex · local models</span></div>
				</div>
				<div class="pillar reveal reveal-delay-2">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent-light)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/></svg>
					<h2>Open source, forever</h2>
					<p>MIT licensed. Read the code, audit the extension, fork it, build on it. Your reflection infrastructure should never be a black box.</p>
					<div class="pillar-foot"><span>MIT licensed · Open source · Local first</span></div>
				</div>
			</div>
		</div>
	</section>

	<!-- DATA PATH -->
	<section class="datapath">
		<div class="wrap">
			<h2 class="center-title reveal" data-inview>The complete data path</h2>
			<div class="path-grid" data-inview>
				{
					dataPath.map((step) => (
						<div class="path-card reveal">
							<div class="path-label">{step.label}</div>
							<p set:html={step.text} />
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- WHEN DATA LEAVES -->
	<section class="leaves">
		<div class="wrap-880">
			<div class="leaves-head reveal" data-inview>
				<h2>When data leaves your machine</h2>
				<p>Most of Retrace works entirely offline: search, network graph, resources, topic extraction, timeline browsing, Life Rivers, Time Capsules. Data only travels when you point an AI app at it over MCP, and that app can be a model you run locally. When you do use a hosted one, it happens under that provider's policy, and you control exactly what it can access.</p>
			</div>
			<div class="provider-grid" data-inview>
				<div class="provider reveal">
					<div><div class="provider-name">Anthropic (Claude)</div><span class="provider-badge teal">Default for reflection</span></div>
					<p>Used for embedded chat and MCP server, via your existing Claude subscription. Anthropic does not train on your data. Conversations are not stored beyond the session.</p>
					<a href="https://www.anthropic.com/legal/privacy" target="_blank" rel="noopener">Anthropic privacy policy &rarr;</a>
				</div>
				<div class="provider reveal reveal-delay-1">
					<div><div class="provider-name">Google (Gemini)</div><span class="provider-badge muted">Optional for automations</span></div>
					<p>Used for scheduled reflections (weekly journal, project pulse). Free tier via AI Studio API key. Google does not use API data to train models.</p>
					<a href="https://ai.google.dev/gemini-api/terms" target="_blank" rel="noopener">Gemini API terms &rarr;</a>
				</div>
				<div class="provider dashed reveal reveal-delay-2">
					<div><div class="provider-name">No provider</div><span class="provider-badge accent">Fully offline</span></div>
					<p>Without a subscription or API key, reflection features are unavailable. Everything else works: browse, search, network graph, topics, Life Rivers, Time Capsules, labels, Obsidian sync.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- SCOPE CONTROL -->
	<section class="scope">
		<div class="wrap-720">
			<div class="scope-head reveal" data-inview>
				<h2>You control what providers see</h2>
				<p>Retrace has a label-based permission system. Tag conversations with labels (platform, topic, or custom), then set allow and block rules per consumer. Claude sees only what you allow.</p>
			</div>
			<div class="scope-rules" data-inview>
				<div class="scope-rule reveal">
					<div class="rule-row">
						<span class="rule-consumer">Embedded chat</span>
						<span class="rule-action block">block</span>
						<span class="rule-label">private</span>
						<span class="rule-label">family</span>
					</div>
					<p>Claude cannot access conversations tagged "private" or "family."</p>
				</div>
				<div class="scope-rule reveal reveal-delay-1">
					<div class="rule-row">
						<span class="rule-consumer">MCP server</span>
						<span class="rule-action allow">allow</span>
						<span class="rule-label">chatgpt</span>
						<span class="rule-label">claude</span>
					</div>
					<p>Claude Desktop can only access your AI conversations, nothing else.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- TECH DETAILS -->
	<section class="tech">
		<div class="wrap-880">
			<h2 class="reveal" data-inview>Technical details</h2>
			<div class="tech-grid" data-inview>
				{
					techDetails.map(([label, value, isCode]) => (
						<div class="tech-row reveal">
							<span class="tech-label">{label}</span>
							{isCode ? <code class="code-teal">{value}</code> : <span class="tech-value">{value}</span>}
						</div>
					))
				}
			</div>
		</div>
	</section>

	<style>
		.wrap { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
		.wrap-760 { max-width: 760px; margin: 0 auto; padding: 0 24px; }
		.wrap-880 { max-width: 880px; margin: 0 auto; padding: 0 24px; }
		.wrap-720 { max-width: 720px; margin: 0 auto; padding: 0 24px; }
		.accent { color: var(--color-accent); }
		.eyebrow { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-caps); margin-bottom: 16px; }
		.eyebrow-accent { color: var(--color-accent); }
		code { font-family: var(--font-mono); }
		.code-teal { font-size: 0.82em; color: var(--color-teal); }

		.page-header { padding: 128px 0 48px; text-align: center; }
		.page-header h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; }
		.page-header p { font-size: 1.15rem; color: var(--color-text-muted); line-height: 1.65; max-width: 560px; margin: 18px auto 0; }

		/* pillars */
		.pillars { padding: var(--space-2xl) 0 var(--space-4xl); }
		.pillar-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
		.pillar { padding: 32px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); }
		.pillar h2 { font-size: 1.2rem; font-weight: 650; letter-spacing: -0.01em; margin-top: 18px; }
		.pillar > p { color: var(--color-text-muted); font-size: 0.93rem; line-height: 1.65; margin-top: 10px; }
		.pillar code { font-size: 0.82em; color: var(--color-teal); }
		.pillar-foot { margin-top: 18px; padding-top: 16px; border-top: 1px solid var(--color-border); display: flex; flex-direction: column; gap: 6px; }
		.pillar-foot .code-teal { background: var(--color-teal-glow); padding: 3px 8px; border-radius: var(--radius-sm); width: fit-content; }
		.pillar-foot span { font-size: 0.85rem; color: var(--color-text-faint); }

		/* data path */
		.datapath { background: var(--color-bg-alt); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding: var(--space-4xl) 0; }
		.center-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; text-align: center; margin-bottom: var(--space-3xl); }
		.path-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
		.path-card { padding: 22px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); }
		.path-label { font-family: var(--font-mono); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-accent); margin-bottom: 10px; }
		.path-card p { font-size: 0.88rem; color: var(--color-text-muted); line-height: 1.5; }
		.path-card :global(code) { font-size: 0.82em; color: var(--color-teal); }

		/* when data leaves */
		.leaves { padding: var(--space-4xl) 0; }
		.leaves-head { margin-bottom: var(--space-2xl); }
		.leaves-head h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; }
		.leaves-head p { color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.7; margin-top: 14px; }
		.provider-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
		.provider { padding: 24px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; gap: 12px; }
		.provider.dashed { border-style: dashed; border-color: var(--color-border-light); }
		.provider-name { font-size: 1.05rem; font-weight: 650; letter-spacing: -0.01em; }
		.provider-badge { display: inline-block; margin-top: 8px; font-size: 10.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 9px; border-radius: var(--radius-full); }
		.provider-badge.teal { color: var(--color-teal); background: var(--color-teal-glow); border: 1px solid rgba(58, 143, 133, 0.2); }
		.provider-badge.muted { color: var(--color-text-faint); background: var(--color-bg-alt); border: 1px solid var(--color-border); }
		.provider-badge.accent { color: var(--color-accent); background: var(--color-accent-glow); border: 1px solid rgba(200, 114, 58, 0.2); }
		.provider p { color: var(--color-text-muted); font-size: 0.88rem; line-height: 1.6; }
		.provider a { color: var(--color-accent); font-size: 0.85rem; font-weight: 500; margin-top: auto; }

		/* scope */
		.scope { background: var(--color-bg-alt); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); padding: var(--space-4xl) 0; }
		.scope-head { margin-bottom: var(--space-2xl); }
		.scope-head h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; }
		.scope-head p { color: var(--color-text-muted); font-size: 1.05rem; line-height: 1.7; margin-top: 14px; }
		.scope-rules { display: flex; flex-direction: column; gap: 16px; }
		.scope-rule { padding: 24px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); }
		.rule-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
		.rule-consumer { font-size: 0.9rem; font-weight: 600; }
		.rule-action { font-family: var(--font-mono); font-size: 10.5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 9px; border-radius: var(--radius-sm); }
		.rule-action.block { color: var(--color-negative); background: rgba(185, 83, 59, 0.1); }
		.rule-action.allow { color: var(--color-positive); background: var(--color-teal-glow); }
		.rule-label { font-size: 12px; font-weight: 500; color: var(--color-text-muted); background: var(--color-bg-alt); border: 1px solid var(--color-border); padding: 3px 11px; border-radius: var(--radius-full); }
		.scope-rule p { font-size: 0.88rem; color: var(--color-text-faint); }

		/* tech */
		.tech { padding: var(--space-4xl) 0; }
		.tech h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 700; letter-spacing: -0.02em; margin-bottom: var(--space-2xl); }
		.tech-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0 40px; max-width: 640px; }
		.tech-row { display: flex; flex-direction: column; gap: 3px; padding: 16px 0; border-bottom: 1px solid var(--color-border); }
		.tech-label { font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-faint); }
		.tech-value { font-size: 0.9rem; color: var(--color-text-muted); }
		.tech-row .code-teal { font-size: 0.85rem; }

		@media (max-width: 900px) {
			.pillar-grid { grid-template-columns: 1fr; }
		}
		@media (max-width: 820px) {
			.path-grid { grid-template-columns: 1fr; }
			.provider-grid { grid-template-columns: 1fr; }
		}
		@media (max-width: 640px) {
			.page-header { padding-top: 100px; }
			.tech-grid { grid-template-columns: 1fr; }
		}
	</style>
</BaseLayout>
