---
import BaseLayout from '../layouts/BaseLayout.astro';
import Glyph from '../components/Glyph.astro';

const importSources = [
	{ name: 'WhatsApp', glyph: 'whatsapp', format: '.txt', desc: 'Export from the app as .txt. Multi-format support, group and DM.' },
	{ name: 'Messenger', glyph: 'messenger', format: '.json', desc: 'Facebook "Download Your Information" JSON export.' },
	{ name: 'Instagram', glyph: 'instagram', format: '.json', desc: 'DM export with multi-file thread merging and encoding fixes.' },
	{ name: 'SMS / MMS', glyph: 'sms', format: '.xml', desc: 'XML from SMS Backup & Restore. Phone numbers normalized.' },
	{ name: 'Google Keep', glyph: 'keep', format: '.html', desc: 'Notes and checklists from Google Takeout.' },
	{ name: 'Calendar', glyph: 'calendar', format: '.ics', desc: 'ICS file parsing with recurring event expansion and day grouping.' },
];

const comingSoon = ['Telegram', 'iMessage', 'Email (sent folder)', 'Gemini'];
---

<BaseLayout active="sources" title="Sources - Retrace" description="Retrace reads from 11 sources. Import, sync, or connect live. Format is always auto-detected.">
	<!-- HEADER -->
	<header class="page-header" data-inview>
		<div class="wrap-narrow">
			<div class="eyebrow eyebrow-accent reveal">sources</div>
			<h1 class="reveal reveal-delay-1">Every platform where you <span class="accent">think and talk.</span></h1>
			<p class="reveal reveal-delay-2">Retrace reads from 11 sources. Import, sync, or connect live. Format is always auto-detected.</p>
		</div>
	</header>

	<!-- BROWSER EXTENSION -->
	<section class="group">
		<div class="wrap">
			<div class="group-head reveal" data-inview>
				<h2>Browser extension</h2>
				<p>Auto-sync from your browser, completely silent.</p>
			</div>
			<div class="cards cards-2" data-inview>
				<div class="card reveal">
					<div class="card-head"><span class="card-title"><Glyph name="chatgpt" size={22} />ChatGPT</span><span class="badge">extension</span></div>
					<p>Background sync of all conversations. Rate-limited, completely silent.</p>
					<div class="card-foot"><code>API</code></div>
				</div>
				<div class="card reveal reveal-delay-1">
					<div class="card-head"><span class="card-title"><Glyph name="claude" size={22} />Claude</span><span class="badge">extension</span></div>
					<p>Background sync of all conversations. Same as ChatGPT.</p>
					<div class="card-foot"><code>API</code></div>
				</div>
			</div>
		</div>
	</section>

	<!-- IMPORT -->
	<section class="group group-alt">
		<div class="wrap">
			<div class="group-head reveal" data-inview>
				<h2>Import</h2>
				<p>Drag and drop, format auto-detected.</p>
			</div>
			<div class="cards cards-3" data-inview>
				{
					importSources.map((s, i) => (
						<div class:list={['card', 'card-sm', { reveal: true, [`reveal-delay-${(i % 3) + 1}`]: true }]}>
							<div class="card-head">
								<span class="card-title sm"><Glyph name={s.glyph} size={20} />{s.name}</span>
								<code>{s.format}</code>
							</div>
							<p>{s.desc}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- LIVE SYNC -->
	<section class="group">
		<div class="wrap">
			<div class="group-head reveal" data-inview>
				<h2>Live sync</h2>
				<p>Real-time, always up to date.</p>
			</div>
			<div class="cards cards-3" data-inview>
				<div class="card reveal">
					<div class="card-head"><span class="card-title"><Glyph name="whatsapp" size={22} />WhatsApp</span><span class="badge">live</span></div>
					<p>Connect via QR code. Real-time messages via Baileys protocol. Auto-reconnect.</p>
					<div class="card-foot"><code>WebSocket</code></div>
				</div>
				<div class="card reveal reveal-delay-1">
					<div class="card-head"><span class="card-title"><Glyph name="obsidian" size={22} />Obsidian</span><span class="badge">live</span></div>
					<p>Vault filesystem watcher. Daily notes sync automatically.</p>
					<div class="card-foot"><code>.md</code></div>
				</div>
				<div class="card reveal reveal-delay-2">
					<div class="card-head"><span class="card-title"><Glyph name="spotify" size={22} />Spotify</span><span class="badge">live</span></div>
					<p>Connect your account once. Listening history syncs automatically, tracks and artists over time.</p>
					<div class="card-foot"><code>OAuth</code></div>
				</div>
			</div>
		</div>
	</section>

	<!-- COMING SOON -->
	<section class="coming">
		<div class="wrap-narrow reveal" data-inview>
			<h2>More sources coming</h2>
			<div class="coming-chips">
				{comingSoon.map((c) => <span class="coming-chip">{c}</span>)}
			</div>
			<a href="https://github.com/aballiet/retrace" target="_blank" rel="noopener" class="roadmap-link">See the full roadmap &rarr;</a>
		</div>
	</section>

	<style>
		.wrap { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
		.wrap-narrow { max-width: 720px; margin: 0 auto; padding: 0 24px; }
		.accent { color: var(--color-accent); }
		.eyebrow { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-caps); margin-bottom: 16px; }
		.eyebrow-accent { color: var(--color-accent); }

		.page-header { padding: 128px 0 48px; text-align: center; }
		.page-header h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; }
		.page-header p { font-size: 1.15rem; color: var(--color-text-muted); line-height: 1.65; max-width: 520px; margin: 18px auto 0; }

		.group { padding: var(--space-3xl) 0; }
		.group-alt { background: var(--color-bg-alt); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border); }
		.group-head { margin-bottom: var(--space-xl); }
		.group-head h2 { font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 700; letter-spacing: -0.02em; }
		.group-head p { color: var(--color-text-muted); font-size: 1rem; margin-top: 6px; }

		.cards { display: grid; gap: 20px; }
		.cards-2 { grid-template-columns: repeat(2, minmax(min(300px, 100%), 1fr)); }
		.cards-3 { grid-template-columns: repeat(3, minmax(min(260px, 100%), 1fr)); }
		.card { padding: 28px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); transition: transform var(--duration-normal) var(--ease-out), box-shadow var(--duration-normal) var(--ease-out), border-color var(--duration-normal) var(--ease-out); }
		.card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: var(--color-border-light); }
		.card-sm { padding: 24px; }
		.card-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; gap: 10px; }
		.card-sm .card-head { margin-bottom: 12px; }
		.card-title { display: flex; align-items: center; gap: 10px; font-size: 1.1rem; font-weight: 650; letter-spacing: -0.01em; }
		.card-title.sm { font-size: 1.02rem; gap: 9px; }
		.card p { color: var(--color-text-muted); font-size: 0.92rem; line-height: 1.6; }
		.card-sm p { font-size: 0.88rem; line-height: 1.55; }
		.badge { font-family: var(--font-mono); font-size: 10.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-teal); background: var(--color-teal-glow); padding: 3px 9px; border-radius: var(--radius-full); white-space: nowrap; }
		.card-foot { margin-top: 16px; }
		code { font-family: var(--font-mono); font-size: 0.78rem; color: var(--color-text-faint); background: var(--color-bg-alt); padding: 3px 8px; border-radius: var(--radius-sm); }
		.card-sm code { font-size: 0.72rem; padding: 2px 7px; }

		.coming { background: var(--color-bg-alt); border-top: 1px solid var(--color-border); padding: var(--space-4xl) 0; text-align: center; }
		.coming h2 { font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 700; letter-spacing: -0.02em; }
		.coming-chips { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin: 24px 0; }
		.coming-chip { font-size: 0.9rem; color: var(--color-text-faint); border: 1px dashed var(--color-border-light); padding: 7px 16px; border-radius: var(--radius-full); }
		.roadmap-link { color: var(--color-accent); font-size: 0.95rem; font-weight: 500; }

		@media (max-width: 760px) {
			.cards-2, .cards-3 { grid-template-columns: 1fr; }
			.page-header { padding-top: 100px; }
		}
	</style>
</BaseLayout>
