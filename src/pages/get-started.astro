---
import BaseLayout from '../layouts/BaseLayout.astro';
import Glyph from '../components/Glyph.astro';
import InteractiveDemoSection from '../components/InteractiveDemoSection.astro';
---

<BaseLayout active="get-started" title="Get Started - Retrace" description="Up and running in five minutes. Export your data, import it locally, and start exploring your conversations.">
	<!-- HEADER -->
	<header class="page-header" data-inview>
		<div aria-hidden="true" class="quote-glyph">&#8220;</div>
		<div class="wrap-720">
			<div class="eyebrow eyebrow-teal reveal">get started</div>
			<h1 class="reveal reveal-delay-1">Up and running in <span class="accent">five minutes.</span></h1>
			<p class="reveal reveal-delay-2">Export your data from the platforms that hold it. Import it locally. Browse, explore, and reflect on your own terms.</p>
		</div>
	</header>

	<!-- HOW IT WORKS -->
	<section class="steps">
		<div class="wrap">
			<!-- 01 -->
			<div class="step reveal" data-inview>
				<div class="step-text">
					<div class="step-meta"><span class="step-num">01</span><span class="chip chip-teal">sync</span></div>
					<h3>Sync with Chrome</h3>
					<p>Install the browser extension. It auto-syncs new ChatGPT, Claude, and Gemini conversations in the background. Rate-limited, completely silent.</p>
				</div>
				<div class="step-visual">
					<div class="sync-row"><Glyph name="chatgpt" size={18} />ChatGPT<span class="status synced">synced</span></div>
					<div class="sync-row"><Glyph name="claude" size={18} />Claude<span class="status synced">synced</span></div>
					<div class="sync-row idle"><span class="sync-placeholder"></span>Gemini<span class="status idle-status">idle</span></div>
				</div>
			</div>

			<!-- 02 -->
			<div class="step flip reveal" data-inview>
				<div class="step-text">
					<div class="step-meta"><span class="step-num">02</span><span class="chip chip-teal">import</span></div>
					<h3>Import or live sync</h3>
					<p>Drop in WhatsApp exports, Messenger archives, Google Keep, calendar files, SMS backups, or Instagram DMs. Format is detected automatically. WhatsApp also connects live via QR code. Obsidian daily notes sync from your vault.</p>
				</div>
				<div class="step-visual glyph-grid">
					<Glyph name="whatsapp" size={22} />
					<Glyph name="messenger" size={22} />
					<Glyph name="instagram" size={22} />
					<Glyph name="sms" size={22} />
					<Glyph name="keep" size={22} />
					<Glyph name="calendar" size={22} />
					<Glyph name="obsidian" size={22} />
				</div>
			</div>

			<!-- 03 -->
			<div class="step reveal" data-inview>
				<div class="step-text">
					<div class="step-meta"><span class="step-num">03</span><span class="chip chip-teal">process</span></div>
					<h3>On-device AI extracts structure</h3>
					<p>Conversations are segmented into meaningful chunks. A local LLM generates summaries, extracts topics, detects emotions, and identifies key facts. Embeddings power semantic search. Choose your model size. All on your machine.</p>
				</div>
				<div class="step-visual">
					<div class="mono-path">on-device · ~/.retrace</div>
					<div class="process-tags">
						<span class="ptag accent">topics</span>
						<span class="ptag teal">summaries</span>
						<span class="ptag accent">embeddings</span>
						<span class="ptag teal">emotions</span>
					</div>
				</div>
			</div>

			<!-- 04 -->
			<div class="step flip insight reveal" data-inview>
				<div class="step-text">
					<div class="step-meta"><span class="step-num">04</span><span class="reflect-chip"><span class="sparkle">&#10022;</span>reflect</span></div>
					<h3>Reflect with Claude</h3>
					<p>Claude is embedded in the app and sees only what you allow. Use labels to control which conversations it can access. Ask about patterns, relationships, or decisions. Also works as an MCP server for Claude Desktop. Uses your existing Claude subscription.</p>
				</div>
				<div class="step-visual chat-visual">
					<div class="chat-q">What did I keep coming back to?</div>
					<div class="chat-a">One thread runs through 23 conversations across 8 months: building something of your own.</div>
				</div>
			</div>

			<!-- 05 -->
			<div class="step reveal" data-inview>
				<div class="step-text">
					<div class="step-meta"><span class="step-num">05</span><span class="chip chip-teal">write-back</span></div>
					<h3>Write back to your tools</h3>
					<p>Reflections save to Obsidian as structured notes with source evidence. Your context layer enriches the tools you already use, not replaces them.</p>
				</div>
				<div class="step-visual obs-visual">
					<div class="obs-title"># Career transition</div>
					<div class="obs-callout">&gt; [!conversation-context]<br />&gt; first raised in a ChatGPT session Jan 15, discussed with Sarah on WhatsApp 3x by Feb.</div>
				</div>
			</div>
		</div>
	</section>

	<!-- DEMO (real, preserved) -->
	<InteractiveDemoSection />

	<!-- CTA -->
	<section class="cta" id="download">
		<div class="wrap reveal" data-inview>
			<div class="cta-mark">
				<svg width="56" height="56" viewBox="0 0 100 100">
					<defs>
						<radialGradient id="sphGs" cx="0.36" cy="0.30" r="0.85"><stop offset="0" stop-color="#dd9059"/><stop offset="0.5" stop-color="#c8723a"/><stop offset="1" stop-color="#2f7a72"/></radialGradient>
						<linearGradient id="ripGs" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#c8723a"/><stop offset="1" stop-color="#3a8f85"/></linearGradient>
					</defs>
					<circle cx="50" cy="35" r="21" fill="url(#sphGs)"/>
					<rect x="21" y="63" width="58" height="6" rx="3" fill="url(#ripGs)" opacity="0.72"/>
					<rect x="28" y="74" width="44" height="4" rx="2" fill="#3a8f85" opacity="0.4"/>
					<rect x="34" y="82" width="32" height="4" rx="2" fill="#3a8f85" opacity="0.22"/>
				</svg>
			</div>
			<h2>Your conversations are waiting. Start reading them back.</h2>
			<div class="cta-buttons">
				<a href="https://github.com/aballiet/retrace/releases/latest" target="_blank" rel="noopener" class="btn btn-primary">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.142-1.64 3.248-1.68.03.13.05.28.05.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.09-2.383 1.37-2.383 4.19 0 3.26 2.854 4.42 2.955 4.45z"/></svg>
					Download for Mac
				</a>
				<a href="#demo" class="btn btn-secondary">Open the demo</a>
			</div>
			<p class="cta-caption">free · runs entirely on your Mac · macOS 12+ · MIT licensed</p>
		</div>
	</section>

	<style>
		.wrap { max-width: 1080px; margin: 0 auto; padding: 0 24px; }
		.wrap-720 { max-width: 720px; margin: 0 auto; padding: 0 24px; position: relative; }
		.accent { color: var(--color-accent); }
		.eyebrow { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-caps); margin-bottom: 16px; }
		.eyebrow-teal { color: var(--color-teal); }

		.page-header { padding: 128px 0 56px; text-align: center; position: relative; overflow: hidden; }
		.quote-glyph { position: absolute; top: -30px; right: 60px; pointer-events: none; user-select: none; font-family: Georgia, 'Times New Roman', serif; font-weight: 700; font-size: clamp(220px, 30vw, 420px); line-height: 1; background: var(--gradient-brand); -webkit-background-clip: text; background-clip: text; color: transparent; -webkit-text-fill-color: transparent; opacity: 0.12; }
		.page-header h1 { font-size: clamp(2.2rem, 5vw, 3.4rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; }
		.page-header p { font-size: 1.15rem; color: var(--color-text-muted); line-height: 1.65; max-width: 540px; margin: 18px auto 0; }

		/* steps */
		.steps { padding: 32px 0 var(--space-4xl); }
		.wrap { display: flex; flex-direction: column; }
		.steps .wrap { gap: 18px; }
		.step { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); padding: 32px; }
		.step.insight { background: var(--gradient-brand-soft); border-color: rgba(200, 114, 58, 0.20); box-shadow: var(--shadow-md); }
		.flip .step-text { order: 2; }
		.flip .step-visual { order: 1; }
		.step-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
		.step-num { font-family: var(--font-mono); font-size: 13px; font-weight: 600; color: var(--color-accent); }
		.chip { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-caps); padding: 4px 11px; border-radius: var(--radius-full); }
		.chip-teal { color: var(--color-teal); background: var(--color-teal-glow); }
		.reflect-chip { display: inline-flex; align-items: center; gap: 6px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-caps); color: #a6592a; }
		.sparkle { font-size: 13px; }
		.step-text h3 { font-size: 1.4rem; font-weight: 650; letter-spacing: -0.015em; }
		.step-text p { font-size: 1rem; color: var(--color-text-muted); line-height: 1.65; margin-top: 12px; max-width: 420px; }

		.step-visual { padding: 20px; background: var(--color-bg); border-radius: var(--radius-md); border: 1px solid var(--color-border); display: flex; flex-direction: column; gap: 10px; }
		.insight .step-visual { background: var(--color-surface); }
		.sync-row { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--color-text-muted); }
		.sync-row.idle { color: var(--color-text-faint); }
		.sync-placeholder { width: 18px; height: 18px; border-radius: 5px; background: var(--color-border); display: block; }
		.status { margin-left: auto; font-family: var(--font-mono); font-size: 11px; }
		.status.synced { color: var(--color-positive); }
		.status.idle-status { color: var(--color-text-faint); }

		.glyph-grid { flex-direction: row; flex-wrap: wrap; gap: 10px; padding: 24px; justify-content: center; align-items: center; }

		.mono-path { font-family: var(--font-mono); font-size: 11px; color: var(--color-text-faint); }
		.process-tags { display: flex; gap: 7px; flex-wrap: wrap; }
		.ptag { font-size: 11.5px; padding: 3px 10px; border-radius: var(--radius-full); }
		.ptag.accent { color: var(--color-accent); background: var(--color-accent-glow); }
		.ptag.teal { color: var(--color-teal); background: var(--color-teal-glow); }

		.chat-visual { gap: 10px; }
		.chat-q { font-size: 13px; font-weight: 500; color: var(--color-text); padding: 8px 12px; background: var(--color-accent-glow); border-radius: var(--radius-md); align-self: flex-end; }
		.chat-a { font-size: 12.5px; color: var(--color-text-muted); line-height: 1.55; padding-left: 12px; border-left: 2px solid var(--color-teal); }

		.obs-visual { font-family: var(--font-mono); font-size: 12px; line-height: 1.7; }
		.obs-title { color: var(--color-text); font-weight: 600; }
		.obs-callout { margin-top: 10px; padding: 10px 12px; border-left: 3px solid var(--color-accent); background: var(--color-accent-glow); border-radius: var(--radius-sm); color: var(--color-text-muted); }

		/* CTA */
		.cta { padding: 104px 0; text-align: center; }
		.cta .wrap { display: block; }
		.cta-mark { display: flex; justify-content: center; margin-bottom: 20px; }
		.cta h2 { font-size: clamp(1.9rem, 4vw, 2.8rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1.08; max-width: 600px; margin: 0 auto; }
		.cta-buttons { display: flex; gap: 12px; justify-content: center; margin-top: 32px; flex-wrap: wrap; }
		.btn { display: inline-flex; align-items: center; gap: 9px; height: 50px; padding: 0 24px; border-radius: var(--radius-full); font-size: 15px; font-weight: 600; transition: transform var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out), border-color var(--duration-fast) var(--ease-out); }
		.btn-primary { background: var(--color-accent); color: var(--color-text-on-accent); box-shadow: var(--shadow-sm); }
		.btn-primary:hover { transform: translateY(-1px); background: var(--color-accent-light); color: var(--color-text-on-accent); }
		.btn-secondary { background: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border); box-shadow: var(--shadow-xs); padding: 0 22px; }
		.btn-secondary:hover { transform: translateY(-1px); border-color: var(--color-border-light); }
		.cta-caption { font-family: var(--font-mono); font-size: 12px; color: var(--color-text-faint); margin-top: 24px; }

		@media (max-width: 820px) {
			.step, .step.flip { grid-template-columns: 1fr; gap: 24px; }
			.flip .step-text { order: 1; }
			.flip .step-visual { order: 2; }
			.step-text p { max-width: none; }
			.page-header { padding-top: 100px; }
		}
	</style>
</BaseLayout>
