---
import BaseLayout from '../layouts/BaseLayout.astro';
import MCPSection from '../components/MCPSection.astro';
import MobileVision from '../components/MobileVision.astro';
import { SearchExplainer } from '../components/animations/SearchExplainer';
import { TimeCapsuleExplainer } from '../components/animations/TimeCapsuleExplainer';
import { GraphExplainer } from '../components/animations/GraphExplainer';
---

<BaseLayout title="Features - Retrace" description="Everything Retrace can do with your conversations. Search, network graph, time capsules, Claude chat, and more.">

<div class="page-header" data-inview>
	<div class="container">
		<h1 class="reveal">Explore, rediscover, <span class="highlight">reflect.</span></h1>
		<p class="reveal reveal-delay-1">
			Everything Retrace can do with your conversations.
		</p>
	</div>
</div>

<!-- Feature 1: Claude Chat -->
<section id="chat" class="feature-section" data-inview>
	<div class="container feature-row">
		<div class="feature-copy reveal">
			<span class="feature-tag">Chat</span>
			<h2>Claude embedded in the app</h2>
			<p>
				Claude lives inside Retrace and sees only what you allow. Use labels to give it
				access to the conversations that matter for your analysis. Ask about patterns,
				reflect on relationships, explore decisions. Your existing Claude subscription
				via the Agent SDK. No API key.
			</p>
		</div>
		<div class="feature-visual reveal reveal-delay-2">
			<div class="mock-chat">
				<div class="chat-msg chat-user">
					<span class="chat-role">You</span>
					<span class="chat-text">What idea have I kept coming back to?</span>
				</div>
				<div class="chat-tools">
					<code>get_topic_timeline(days=90)</code>
					<code>semantic_search("keep returning excited")</code>
				</div>
				<div class="chat-msg chat-claude">
					<span class="chat-role">Claude</span>
					<span class="chat-text">One thread runs through 23 conversations across three months: building something of your own. It shows up in a ChatGPT session in January, three WhatsApp messages in February, and six Claude conversations in March. Each time the tone is the same: energized, specific, a little scared.</span>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Feature 2: Search -->
<section id="search" class="feature-section alt" data-inview>
	<div class="container feature-row reverse">
		<div class="feature-copy reveal">
			<span class="feature-tag">Search</span>
			<h2>Find anything you ever said</h2>
			<p>
				Search by meaning, not just keywords. "That restaurant someone recommended last summer" works.
				384-dimensional embeddings power similarity search across all platforms in one query.
			</p>
			<SearchExplainer client:visible />
		</div>
		<div class="feature-visual reveal reveal-delay-2">
			<div class="mock-search">
				<div class="search-bar">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none"><circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="1.5"/><path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
					<span>restaurant recommendation last summer</span>
				</div>
				<div class="search-results">
					<div class="search-result">
						<span class="result-platform platform-whatsapp">WhatsApp</span>
						<span class="result-title">Sarah &middot; Jul 2025</span>
						<span class="result-snippet">"You have to try Maison Plisson, it's exactly your vibe"</span>
					</div>
					<div class="search-result">
						<span class="result-platform platform-chatgpt">ChatGPT</span>
						<span class="result-title">Paris trip planning &middot; Aug 2025</span>
						<span class="result-snippet">"Based on your preferences, I'd recommend these restaurants in the 3rd..."</span>
					</div>
					<div class="search-result">
						<span class="result-platform platform-messenger">Messenger</span>
						<span class="result-title">Tom &middot; Aug 2025</span>
						<span class="result-snippet">"We ended up at that place Sarah mentioned, it was incredible"</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Feature 3: Network Graph -->
<section id="network" class="feature-section" data-inview>
	<div class="container feature-row">
		<div class="feature-copy reveal">
			<span class="feature-tag">Network</span>
			<h2>See your social graph</h2>
			<p>
				Force-directed visualization of your relationships. Tie-strength scoring reveals
				your inner circle. Timelapse animation shows connections forming over months.
				Dunbar-inspired tiers from inner circle to periphery.
			</p>
			<GraphExplainer client:visible />
		</div>
		<div class="feature-visual reveal reveal-delay-2">
			<div class="mock-graph">
				<svg viewBox="0 0 300 220" class="graph-svg">
					<!-- Edges -->
					<line x1="150" y1="110" x2="80" y2="60" stroke="var(--color-accent)" stroke-width="2" opacity="0.6"/>
					<line x1="150" y1="110" x2="220" y2="70" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>
					<line x1="150" y1="110" x2="100" y2="170" stroke="var(--color-teal)" stroke-width="2.5" opacity="0.7"/>
					<line x1="150" y1="110" x2="230" y2="160" stroke="var(--color-accent-light)" stroke-width="1" opacity="0.3"/>
					<line x1="150" y1="110" x2="60" y2="130" stroke="var(--color-teal)" stroke-width="1.5" opacity="0.5"/>
					<line x1="80" y1="60" x2="60" y2="130" stroke="var(--color-border-light)" stroke-width="1" opacity="0.3"/>
					<line x1="220" y1="70" x2="230" y2="160" stroke="var(--color-border-light)" stroke-width="1" opacity="0.2"/>
					<!-- Center node (you) -->
					<circle cx="150" cy="110" r="14" fill="var(--color-accent)" opacity="0.9"/>
					<text x="150" y="114" text-anchor="middle" fill="white" font-size="8" font-weight="600">You</text>
					<!-- Inner circle -->
					<circle cx="80" cy="60" r="10" fill="var(--color-teal)" opacity="0.8"/>
					<text x="80" y="44" text-anchor="middle" fill="var(--color-text-muted)" font-size="7.5">Sarah</text>
					<circle cx="100" cy="170" r="11" fill="var(--color-teal)" opacity="0.8"/>
					<text x="100" y="190" text-anchor="middle" fill="var(--color-text-muted)" font-size="7.5">Tom</text>
					<!-- Active -->
					<circle cx="220" cy="70" r="8" fill="var(--color-accent-light)" opacity="0.6"/>
					<text x="220" y="56" text-anchor="middle" fill="var(--color-text-faint)" font-size="7">Maya</text>
					<circle cx="60" cy="130" r="7" fill="var(--color-accent-light)" opacity="0.5"/>
					<text x="45" y="125" text-anchor="middle" fill="var(--color-text-faint)" font-size="7">Alex</text>
					<!-- Extended -->
					<circle cx="230" cy="160" r="5" fill="var(--color-text-faint)" opacity="0.4"/>
					<text x="252" y="163" text-anchor="middle" fill="var(--color-text-faint)" font-size="6.5">Jules</text>
				</svg>
				<div class="graph-legend">
					<span class="legend-item"><span class="legend-dot dot-inner"></span> Inner circle</span>
					<span class="legend-item"><span class="legend-dot dot-active"></span> Active</span>
					<span class="legend-item"><span class="legend-dot dot-extended"></span> Extended</span>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Feature 4: Time Capsules -->
<section id="capsules" class="feature-section alt" data-inview>
	<div class="container feature-row reverse">
		<div class="feature-copy reveal">
			<span class="feature-tag">Capsules</span>
			<h2>This time last year</h2>
			<p>
				Rediscover what you were thinking, feeling, and doing a year ago. AI-powered
				then-and-now comparisons surface what's changed, what echoes, and what you
				forgot entirely. Reflections grounded in your actual conversations.
			</p>
			<TimeCapsuleExplainer client:visible />
		</div>
		<div class="feature-visual reveal reveal-delay-2">
			<div class="mock-capsule">
				<div class="capsule-half capsule-then">
					<div class="capsule-label">Then &middot; April 2025</div>
					<p>"Thinking about leaving my job but scared to take the leap. Talked to Sarah about it three times this month."</p>
				</div>
				<div class="capsule-divider"></div>
				<div class="capsule-half capsule-now">
					<div class="capsule-label">Now &middot; April 2026</div>
					<p>"Six months into the new role. The fear is gone. Conversations shifted from doubt to planning."</p>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Feature 5: Life Rivers -->
<section class="feature-section" data-inview>
	<div class="container feature-row">
		<div class="feature-copy reveal">
			<span class="feature-tag">Rivers</span>
			<h2>Watch your life flow</h2>
			<p>
				Streamgraph visualization of conversations over time, colored by person or topic.
				See where your attention goes and how it shifts. Discover patterns in who you
				talk to and what you talk about.
			</p>
		</div>
		<div class="feature-visual reveal reveal-delay-2">
			<div class="mock-river">
				<svg viewBox="0 0 320 140" class="river-svg">
					<defs>
						<linearGradient id="g1" x1="0" x2="1" y1="0" y2="0">
							<stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.1"/>
							<stop offset="50%" stop-color="var(--color-accent)" stop-opacity="0.4"/>
							<stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0.2"/>
						</linearGradient>
						<linearGradient id="g2" x1="0" x2="1" y1="0" y2="0">
							<stop offset="0%" stop-color="var(--color-teal)" stop-opacity="0.15"/>
							<stop offset="50%" stop-color="var(--color-teal)" stop-opacity="0.35"/>
							<stop offset="100%" stop-color="var(--color-teal)" stop-opacity="0.25"/>
						</linearGradient>
						<linearGradient id="g3" x1="0" x2="1" y1="0" y2="0">
							<stop offset="0%" stop-color="var(--color-accent-light)" stop-opacity="0.1"/>
							<stop offset="50%" stop-color="var(--color-accent-light)" stop-opacity="0.3"/>
							<stop offset="100%" stop-color="var(--color-accent-light)" stop-opacity="0.15"/>
						</linearGradient>
					</defs>
					<!-- Stream layers -->
					<path d="M0,80 C60,75 100,50 160,45 S260,55 320,60 L320,85 C260,80 200,70 160,72 S60,82 0,85 Z" fill="url(#g1)"/>
					<path d="M0,68 C60,62 120,40 180,35 S260,42 320,48 L320,60 C260,55 200,45 160,45 S60,58 0,65 Z" fill="url(#g2)"/>
					<path d="M0,90 C80,92 120,100 180,95 S250,88 320,92 L320,105 C250,100 200,108 160,110 S80,105 0,100 Z" fill="url(#g3)"/>
					<!-- Time labels -->
					<text x="20" y="130" fill="var(--color-text-faint)" font-size="8">Jan</text>
					<text x="80" y="130" fill="var(--color-text-faint)" font-size="8">Mar</text>
					<text x="155" y="130" fill="var(--color-text-faint)" font-size="8">Jun</text>
					<text x="230" y="130" fill="var(--color-text-faint)" font-size="8">Sep</text>
					<text x="295" y="130" fill="var(--color-text-faint)" font-size="8">Dec</text>
				</svg>
				<div class="river-legend">
					<span class="legend-item"><span class="legend-dot" style="background: var(--color-accent)"></span> Career</span>
					<span class="legend-item"><span class="legend-dot" style="background: var(--color-teal)"></span> Health</span>
					<span class="legend-item"><span class="legend-dot" style="background: var(--color-accent-light)"></span> Relationships</span>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Feature 6: Obsidian Write-back -->
<section class="feature-section alt" data-inview>
	<div class="container feature-row reverse">
		<div class="feature-copy reveal">
			<span class="feature-tag">Write-back</span>
			<h2>Enriches your existing tools</h2>
			<p>
				Reflections sync to Obsidian as structured callout blocks with source evidence.
				Retrace makes your vault smarter, never replaces it. Your vault, your words, augmented.
			</p>
		</div>
		<div class="feature-visual reveal reveal-delay-2">
			<div class="mock-obsidian">
				<div class="obs-title"># Career transition</div>
				<div class="obs-body">Decided to leave the role after three months of deliberation...</div>
				<div class="obs-callout">
					<div class="obs-callout-header">&gt; [!conversation-context]</div>
					<div class="obs-callout-title">&gt; ## From your conversations</div>
					<div class="obs-callout-body">&gt; You first mentioned this in a ChatGPT session on Jan 15. By Feb, you'd discussed it with Sarah (WhatsApp, 3 times) and Tom (Messenger). Your tone shifted from anxious to resolved by mid-March.</div>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Feature 7: Labels -->
<section class="feature-section" data-inview>
	<div class="container feature-row">
		<div class="feature-copy reveal">
			<span class="feature-tag">Scope</span>
			<h2>Labels and permissions</h2>
			<p>
				Tag conversations with labels. Set allow/block rules per consumer. Your private
				conversations stay private, even from your own agents. Platform labels are automatic.
				Topic labels are extracted by AI. Custom labels are yours.
			</p>
		</div>
		<div class="feature-visual reveal reveal-delay-2">
			<div class="mock-labels">
				<div class="label-row">
					<span class="label label-platform">whatsapp</span>
					<span class="label label-platform">messenger</span>
					<span class="label label-topic">career</span>
					<span class="label label-topic">health</span>
					<span class="label label-user">private</span>
					<span class="label label-user">family</span>
				</div>
				<div class="label-rule">
					<span class="rule-consumer">Embedded chat</span>
					<span class="rule-action rule-block">Block</span>
					<span class="label label-user">private</span>
				</div>
				<div class="label-rule">
					<span class="rule-consumer">MCP server</span>
					<span class="rule-action rule-allow">Allow</span>
					<span class="label label-platform">chatgpt</span>
					<span class="label label-platform">claude</span>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- MCP deep dive -->
<MCPSection />

<!-- Mobile vision -->
<MobileVision />

<!-- CTA -->
<section class="feature-cta">
	<div class="container">
		<div class="cta-inner" data-inview>
			<h2 class="reveal">Ready to explore your conversations?</h2>
			<div class="cta-buttons reveal reveal-delay-1">
				<a href="https://github.com/aballiet/retrace/releases/latest" target="_blank" rel="noopener" class="btn btn-primary">Download for macOS</a>
				<a href="/get-started" class="btn btn-secondary">See how it works</a>
			</div>
		</div>
	</div>
</section>

</BaseLayout>

<style>
	.page-header {
		padding-top: 140px;
		padding-bottom: var(--space-xl);
		text-align: center;
	}

	.page-header h1 {
		font-size: clamp(2rem, 5vw, 3.25rem);
		font-weight: 700;
		letter-spacing: -0.03em;
		line-height: 1.15;
		margin-bottom: var(--space-lg);
	}

	.highlight {
		background: linear-gradient(135deg, var(--color-accent), var(--color-accent-light));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.page-header p {
		color: var(--color-text-muted);
		font-size: 1.15rem;
		max-width: 480px;
		margin: 0 auto;
	}

	/* Feature sections */
	.feature-section { padding: var(--space-4xl) 0; }
	.feature-section.alt {
		background: var(--color-bg-alt);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.feature-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-3xl);
		align-items: center;
	}

	.feature-row.reverse { direction: rtl; }
	.feature-row.reverse > * { direction: ltr; }

	.feature-tag {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--color-teal);
		background: var(--color-teal-glow);
		padding: 0.25em 0.75em;
		border-radius: var(--radius-full);
		margin-bottom: var(--space-lg);
	}

	.feature-copy h2 {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-md);
	}

	.feature-copy p {
		color: var(--color-text-muted);
		font-size: 1rem;
		line-height: 1.7;
	}

	/* Visual mockups - shared */
	.feature-visual {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		padding: var(--space-xl);
		overflow: hidden;
	}

	/* Mock chat */
	.mock-chat { display: flex; flex-direction: column; gap: var(--space-md); }
	.chat-msg { display: flex; flex-direction: column; gap: var(--space-xs); }
	.chat-role {
		font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
		text-transform: uppercase; color: var(--color-text-faint);
	}
	.chat-claude .chat-role { color: var(--color-teal); }
	.chat-text { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.65; }
	.chat-tools {
		display: flex; flex-direction: column; gap: var(--space-xs); padding-left: var(--space-md);
	}
	.chat-tools code {
		font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-teal);
		background: var(--color-teal-glow); padding: 0.2em 0.6em;
		border-radius: var(--radius-sm); width: fit-content;
	}

	/* Mock search */
	.mock-search { display: flex; flex-direction: column; gap: var(--space-md); }
	.search-bar {
		display: flex; align-items: center; gap: var(--space-sm);
		padding: var(--space-sm) var(--space-md);
		border: 1px solid var(--color-border); border-radius: var(--radius-full);
		color: var(--color-text-muted); font-size: 0.85rem;
	}
	.search-results { display: flex; flex-direction: column; gap: var(--space-sm); }
	.search-result {
		display: flex; flex-direction: column; gap: 2px;
		padding: var(--space-sm) var(--space-md);
		border-radius: var(--radius-md); background: var(--color-bg);
	}
	.result-platform {
		font-size: 0.7rem; font-weight: 600; letter-spacing: 0.06em;
		text-transform: uppercase; width: fit-content;
		padding: 0.1em 0.5em; border-radius: var(--radius-sm);
	}
	.platform-whatsapp { color: #25D366; background: rgba(37, 211, 102, 0.1); }
	.platform-chatgpt { color: #10A37F; background: rgba(16, 163, 127, 0.1); }
	.platform-messenger { color: #0084FF; background: rgba(0, 132, 255, 0.1); }
	.result-title { font-size: 0.8rem; font-weight: 500; color: var(--color-text); }
	.result-snippet { font-size: 0.8rem; color: var(--color-text-faint); font-style: italic; }

	/* Mock graph */
	.mock-graph { text-align: center; }
	.graph-svg { width: 100%; max-width: 420px; height: auto; }
	.graph-legend, .river-legend {
		display: flex; gap: var(--space-md); justify-content: center;
		margin-top: var(--space-md);
	}
	.legend-item {
		display: flex; align-items: center; gap: var(--space-xs);
		font-size: 0.75rem; color: var(--color-text-faint);
	}
	.legend-dot { width: 8px; height: 8px; border-radius: 50%; }
	.dot-inner { background: var(--color-teal); }
	.dot-active { background: var(--color-accent-light); }
	.dot-extended { background: var(--color-text-faint); opacity: 0.5; }

	/* Mock capsule */
	.mock-capsule { display: flex; gap: var(--space-md); align-items: stretch; }
	.capsule-half { flex: 1; }
	.capsule-label {
		font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600;
		letter-spacing: 0.06em; text-transform: uppercase;
		margin-bottom: var(--space-sm);
	}
	.capsule-then .capsule-label { color: var(--color-text-faint); }
	.capsule-now .capsule-label { color: var(--color-accent); }
	.capsule-half p { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; }
	.capsule-divider { width: 1px; background: var(--color-border); flex-shrink: 0; }

	/* Mock river */
	.mock-river { text-align: center; }
	.river-svg { width: 100%; height: auto; }

	/* Mock obsidian */
	.mock-obsidian { font-family: var(--font-mono); font-size: 0.82rem; line-height: 1.7; }
	.obs-title { font-weight: 700; color: var(--color-text); margin-bottom: var(--space-sm); font-family: var(--font-sans); font-size: 1rem; }
	.obs-body { color: var(--color-text-muted); margin-bottom: var(--space-lg); font-family: var(--font-sans); font-size: 0.9rem; }
	.obs-callout {
		background: var(--color-accent-glow);
		border-left: 3px solid var(--color-accent);
		border-radius: var(--radius-sm);
		padding: var(--space-md);
		display: flex; flex-direction: column; gap: var(--space-xs);
	}
	.obs-callout-header { font-size: 0.72rem; color: var(--color-accent); opacity: 0.7; }
	.obs-callout-title { font-size: 0.82rem; font-weight: 600; color: var(--color-accent); font-family: var(--font-sans); }
	.obs-callout-body { font-size: 0.82rem; color: var(--color-text-muted); font-family: var(--font-sans); line-height: 1.6; }

	/* Mock labels */
	.mock-labels { display: flex; flex-direction: column; gap: var(--space-lg); }
	.label-row { display: flex; gap: var(--space-sm); flex-wrap: wrap; }
	.label {
		font-size: 0.72rem; font-weight: 600; letter-spacing: 0.04em;
		padding: 0.25em 0.7em; border-radius: var(--radius-full);
	}
	.label-platform { color: var(--color-teal); background: var(--color-teal-glow); border: 1px solid rgba(58, 143, 133, 0.2); }
	.label-topic { color: var(--color-accent); background: var(--color-accent-glow); border: 1px solid rgba(200, 114, 58, 0.2); }
	.label-user { color: var(--color-text-muted); background: var(--color-surface); border: 1px solid var(--color-border); }
	.label-rule {
		display: flex; align-items: center; gap: var(--space-sm);
		padding: var(--space-sm) var(--space-md);
