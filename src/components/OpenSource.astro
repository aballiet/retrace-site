---
---

<section id="download" class="open-source">
	<div class="container">
		<div class="cta-card" data-inview>
			<div class="cta-content reveal">
				<p class="cta-tag">Open Source</p>
				<h2>Built for people who think carefully.</h2>
				<p class="cta-desc">
					Retrace is free and MIT licensed. Try the interactive demo, explore the
					source code, or star the repo to follow development. Claude is embedded
					using your existing subscription. No account. No API key. No vendor lock-in.
				</p>
				<div class="download-block">
					<a href="https://github.com/aballiet/retrace-releases/releases/latest/download/Retrace.dmg" class="btn btn-primary btn-download">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
							<path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12 0-.23-.02-.3-.03-.01-.06-.04-.22-.04-.39 0-1.15.572-2.27 1.206-2.98.804-.94 2.142-1.64 3.248-1.68.03.13.05.28.05.43zm4.565 15.71c-.03.07-.463 1.58-1.518 3.12-.945 1.34-1.94 2.71-3.43 2.71-1.517 0-1.9-.88-3.63-.88-1.698 0-2.302.91-3.67.91-1.377 0-2.332-1.26-3.428-2.8-1.287-1.82-2.323-4.63-2.323-7.28 0-4.28 2.797-6.55 5.552-6.55 1.448 0 2.675.95 3.6.95.865 0 2.222-1.01 3.902-1.01.613 0 2.886.06 4.374 2.19-.13.09-2.383 1.37-2.383 4.19 0 3.26 2.854 4.42 2.955 4.45z"/>
						</svg>
						<span class="btn-label">
							Download for Mac
							<span class="btn-sub">Free &middot; Apple Silicon &middot; macOS 12+</span>
						</span>
					</a>
					<div class="secondary-actions">
						<a href="#demo" class="btn btn-secondary">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<polygon points="5 3 19 12 5 21 5 3" />
							</svg>
							Try the live demo
						</a>
						<a href="https://github.com/aballiet/retrace" target="_blank" rel="noopener" class="btn btn-secondary">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
							</svg>
							View on GitHub
						</a>
					</div>
					<p class="download-note">On first open, right-click the app and choose Open. Runs entirely on your Mac.</p>
				</div>
			</div>
		</div>

		<div class="stats" data-inview>
			<div class="stat reveal reveal-delay-1">
				<span class="stat-value">10</span>
				<span class="stat-label">Sources</span>
			</div>
			<div class="stat reveal reveal-delay-2">
				<span class="stat-value">$0</span>
				<span class="stat-label">API costs</span>
			</div>
			<div class="stat reveal reveal-delay-3">
				<span class="stat-value">MIT</span>
				<span class="stat-label">Licensed</span>
			</div>
			<div class="stat reveal reveal-delay-4">
				<span class="stat-value">100%</span>
				<span class="stat-label">Your data</span>
			</div>
		</div>
	</div>
</section>

<style>
	.open-source {
		padding-bottom: var(--space-4xl);
	}

	.cta-card {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		overflow: hidden;
	}

	.cta-content {
		padding: var(--space-4xl);
	}

	.cta-tag {
		display: inline-block;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-accent);
		margin-bottom: var(--space-lg);
	}

	h2 {
		font-size: clamp(1.5rem, 3.5vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		margin-bottom: var(--space-lg);
		max-width: 500px;
	}

	.cta-desc {
		color: var(--color-text-muted);
		font-size: 1.05rem;
		line-height: 1.7;
		max-width: 540px;
		margin-bottom: var(--space-2xl);
	}

	.download-block {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
		align-items: flex-start;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: var(--space-sm);
		padding: 0.85rem 1.75rem;
		border-radius: var(--radius-full);
		font-weight: 600;
		font-size: 0.95rem;
		transition: all var(--duration-fast) ease;
		white-space: nowrap;
	}

	.btn-download {
		padding: 0.9rem 1.75rem;
	}

	.btn-label {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.btn-sub {
		font-size: 0.75rem;
		font-weight: 400;
		opacity: 0.75;
	}

	.btn-primary {
		background: var(--color-primary);
		color: var(--color-bg);
	}

	.btn-primary:hover {
		background: var(--color-text-muted);
		color: var(--color-bg);
		transform: translateY(-2px);
		box-shadow: 0 8px 30px rgba(45, 42, 38, 0.15);
	}

	.btn-secondary {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-secondary:hover {
		background: var(--color-surface-hover);
		border-color: var(--color-border-light);
		transform: translateY(-2px);
	}

	.secondary-actions {
		display: flex;
		gap: var(--space-md);
		flex-wrap: wrap;
	}

	.chrome-note {
		display: flex;
		align-items: center;
		gap: var(--space-sm);
		font-size: 0.85rem;
		color: var(--color-text-faint);
	}

	.download-note {
		font-size: 0.85rem;
		color: var(--color-text-faint);
		max-width: 420px;
		line-height: 1.5;
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--space-xl);
		margin-top: var(--space-4xl);
		text-align: center;
	}

	.stat {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
	}

	.stat-value {
		font-size: clamp(1.5rem, 3vw, 2.25rem);
		font-weight: 700;
		color: var(--color-accent);
		letter-spacing: -0.02em;
	}

	.stat-label {
		font-size: 0.85rem;
		color: var(--color-text-faint);
		font-weight: 450;
	}

	@media (max-width: 768px) {
		.btn {
			min-height: 44px;
		}
	}

	@media (max-width: 480px) {
		.cta-content {
			padding: var(--space-xl);
		}
	}

	@media (max-width: 768px) {
		.cta-content {
			padding: var(--space-2xl);
		}

		.stats {
			grid-template-columns: repeat(2, 1fr);
			gap: var(--space-xl) var(--space-md);
		}

		.secondary-actions {
			flex-direction: column;
		}

		.btn {
			justify-content: center;
		}
	}
</style>
