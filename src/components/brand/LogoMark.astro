---
/**
 * Retrace brand mark — the reflection mark: a terracotta circle with three
 * descending, fading ripple bars (the object and its reflection).
 * Default renders solid terracotta; variant "mono" fills with `color`
 * (e.g. white inside the hero hub, cream for the privacy watermark).
 */
interface Props {
	size?: number;
	variant?: 'solid' | 'mono';
	color?: string;
	/** Accepted for call-site compatibility; not used by the solid mark. */
	gradId?: string;
	class?: string;
}

const { size = 24, variant = 'solid', color = '#c8723a', class: className } = Astro.props;
const fill = variant === 'mono' ? color : '#c8723a';
---

<svg
	width={size}
	height={size}
	viewBox="0 0 100 100"
	role="img"
	aria-label="retrace"
	class={className}
	style="display:block;flex-shrink:0;"
>
	<circle cx="50" cy="35" r="21" fill={fill} />
	<rect x="21" y="63" width="58" height="6" rx="3" fill={fill} opacity="0.72" />
	<rect x="28" y="74" width="44" height="4" rx="2" fill={fill} opacity="0.4" />
	<rect x="34" y="82" width="32" height="4" rx="2" fill={fill} opacity="0.22" />
</svg>
