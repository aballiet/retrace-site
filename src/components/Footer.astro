---
---

<footer class="footer">
	<div class="container">
		<div class="footer-inner">
			<div class="footer-brand">
				<a href="/" class="logo">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none">
						<path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z" stroke="var(--color-accent)" stroke-width="1.5" fill="none" opacity="0.3"/>
						<path d="M8 6c2 4 2 8 0 12" stroke="var(--color-accent)" stroke-width="1.5" stroke-linecap="round"/>
						<path d="M12 4v16" stroke="var(--color-teal)" stroke-width="1.5" stroke-linecap="round"/>
						<path d="M16 6c-2 4-2 8 0 12" stroke="var(--color-accent-light)" stroke-width="1.5" stroke-linecap="round"/>
					</svg>
					<span>Retrace</span>
				</a>
				<p>Context, not destination.</p>
			</div>

			<div class="footer-links">
				<div class="footer-col">
					<h4>Product</h4>
					<a href="/features">Features</a>
					<a href="/sources">Sources</a>
					<a href="/privacy">Privacy</a>
					<a href="/get-started">Get Started</a>
				</div>
				<div class="footer-col">
					<h4>Docs</h4>
					<a href="/docs">Overview</a>
					<a href="/docs/getting-started">Quick Start</a>
					<a href="/docs/import/whatsapp">Import Guides</a>
					<a href="/docs/developer/architecture">Developer</a>
				</div>
				<div class="footer-col">
					<h4>Community</h4>
					<a href="https://github.com/aballiet/retrace" target="_blank" rel="noopener">GitHub</a>
					<a href="https://github.com/aballiet/retrace/issues" target="_blank" rel="noopener">Issues</a>
					<a href="https://github.com/aballiet/retrace/blob/main/docs/roadmap.md" target="_blank" rel="noopener">Roadmap</a>
				</div>
				<div class="footer-col">
					<h4>Legal</h4>
					<a href="https://github.com/aballiet/retrace/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a>
				</div>
			</div>
		</div>

		<div class="footer-bottom">
			<p>Made with care by <a href="https://github.com/aballiet" target="_blank" rel="noopener">Antoine Balliet</a></p>
		</div>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border);
		padding: var(--space-4xl) 0 var(--space-2xl);
	}

	.footer-inner {
		display: flex;
		justify-content: space-between;
		gap: var(--space-4xl);
		margin-bottom: var(--space-3xl);
	}

	.footer-brand { max-width: 300px; }

	.logo {
		display: inline-flex;
		align-items: center;
		gap: var(--space-sm);
		color: var(--color-text);
		font-weight: 600;
		font-size: 1rem;
		margin-bottom: var(--space-md);
	}

	.logo:hover { color: var(--color-text); }

	.footer-brand p {
		font-size: 0.9rem;
		color: var(--color-text-faint);
		line-height: 1.6;
	}

	.footer-links {
		display: flex;
		gap: var(--space-4xl);
	}

	.footer-col {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	h4 {
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-text);
		margin-bottom: var(--space-sm);
	}

	.footer-col a {
		color: var(--color-text-faint);
		font-size: 0.9rem;
		transition: color var(--duration-fast) ease;
	}

	.footer-col a:hover { color: var(--color-text-muted); }

	.footer-bottom {
		padding-top: var(--space-2xl);
		border-top: 1px solid var(--color-border);
	}

	.footer-bottom p {
		font-size: 0.85rem;
		color: var(--color-text-faint);
	}

	@media (max-width: 768px) {
		.footer-inner {
			flex-direction: column;
			gap: var(--space-2xl);
		}

		.footer-links {
			flex-wrap: wrap;
			gap: var(--space-2xl);
		}
	}
</style>
