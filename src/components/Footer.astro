---
import LogoMark from './brand/LogoMark.astro';
---

<footer class="footer">
	<div class="footer-grid">
		<div class="footer-brand">
			<a href="/" class="logo" aria-label="retrace home">
				<LogoMark size={22} gradId="footerLogoGrad" />
				<span>retrace</span>
			</a>
			<p>Rediscover your conversations. Your data is stored locally, you choose what leaves.</p>
		</div>

		<div class="footer-col">
			<h4>Product</h4>
			<a href="/features">Features</a>
			<a href="/sources">Sources</a>
			<a href="/privacy">Privacy</a>
			<a href="/#download">Download</a>
		</div>

		<div class="footer-col">
			<h4>Resources</h4>
			<a href="/get-started">Get started</a>
			<a href="/get-started#demo">Demo</a>
			<a href="/features#mcp">MCP server</a>
		</div>

		<div class="footer-col">
			<h4>Project</h4>
			<a href="https://github.com/aballiet/retrace" target="_blank" rel="noopener">Open source</a>
			<a href="/privacy">Privacy</a>
			<a href="https://github.com/aballiet/retrace" target="_blank" rel="noopener">GitHub</a>
		</div>
	</div>
	<div class="footer-bottom">© 2026 retrace · retrace.now</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border);
		background: var(--color-bg-alt);
	}
	.footer-grid {
		max-width: 1080px;
		margin: 0 auto;
		padding: 48px 24px 24px;
		display: grid;
		grid-template-columns: 1.6fr 1fr 1fr 1fr;
		gap: 32px;
	}
	.footer-brand .logo {
		display: flex;
		align-items: center;
		gap: 9px;
		color: var(--color-text);
		font-size: 18px;
		font-weight: 600;
		letter-spacing: var(--tracking-wordmark);
	}
	.footer-brand p {
		font-size: 13px;
		color: var(--color-text-faint);
		margin-top: 14px;
		max-width: 250px;
		line-height: 1.5;
	}
	.footer-col h4 {
		font-size: 13px;
		font-weight: 600;
		margin-bottom: 12px;
		color: var(--color-text);
	}
	.footer-col {
		display: flex;
		flex-direction: column;
		gap: 9px;
	}
	.footer-col a {
		font-size: 13.5px;
		color: var(--color-text-muted);
		transition: color var(--duration-fast) ease;
	}
	.footer-col a:hover { color: var(--color-text); }
	.footer-bottom {
		max-width: 1080px;
		margin: 0 auto;
		padding: 0 24px 28px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: var(--color-text-faint);
	}

	@media (max-width: 760px) {
		.footer-grid { grid-template-columns: 1fr 1fr; }
		.footer-brand { grid-column: 1 / -1; }
	}
</style>
